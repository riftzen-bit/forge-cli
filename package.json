{
  "name": "forge-cli",
  "version": "0.1.0",
  "description": "Forge — terminal-native coding agent powered by Claude.",
  "type": "module",
  "bin": {
    "forge": "./bin/forge.mjs",
    "map": "./bin/forge.mjs"
  },
  "files": [
    "bin",
    "dist"
  ],
  "scripts": {
    "dev": "bun run src/cli.tsx",
    "build": "bun build src/cli.tsx --outdir dist --target node --format esm --packages external",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.0",
    "commander": "^12.1.0",
    "ink": "^5.0.1",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "@types/react": "^18.3.3",
    "typescript": "^5.5.4",
    "eslint": "^9.9.0"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": ["cli", "ai", "claude", "agent", "coding", "forge"],
  "license": "MIT"
}
